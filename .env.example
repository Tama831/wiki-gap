# Copy this file to `.env` and fill in your own values.
# ─────────────────────────────────────────────────────────

# ─── Required: a contact for Wikimedia ────────────────────
# Sent to Wikimedia in the User-Agent header so they can reach you if this
# tool's API requests cause trouble. Required by their policy:
#   https://foundation.wikimedia.org/wiki/Policy:User-Agent_policy
# It does NOT have to be GitHub. Anything you can be reached at works:
#   - an email:             mailto:you@example.com
#   - a website:            https://example.com/about
#   - a Wikipedia userpage: https://en.wikipedia.org/wiki/User:YourName
WIKI_GAP_CONTACT_URL=https://en.wikipedia.org/wiki/User:YourName

# SQLite DB path (relative to project root by default)
WIKI_GAP_DB_PATH=data/wiki_gap.db

# Crawl rate limit (req/sec)
WIKI_GAP_RATE_LIMIT=1.5

# Wikidata SPARQL endpoint
WIKIDATA_SPARQL_ENDPOINT=https://query.wikidata.org/sparql

# ─── Optional: dashboard bind (default = localhost only) ──
# Leave as-is to use only on this machine. Override with your Tailscale IP
# or your tunnel IP if you want to access the dashboard from elsewhere.
# Example: WIKI_GAP_BIND_HOST=100.x.x.x  (your `tailscale ip -4` output)
WIKI_GAP_BIND_HOST=127.0.0.1
WIKI_GAP_BIND_PORT=8766

# ─── Optional: Wikipedia OAuth 2.0 (only to POST to Wikipedia) ─
# Leave blank to just browse gaps. Needed only for the posting feature.
# Register a consumer at:
#   https://meta.wikimedia.org/wiki/Special:OAuthConsumerRegistration/propose/oauth2
# (Wikipedia mandates HTTPS for non-local callbacks. If your dashboard is
#  only reachable over plain HTTP, use a localhost/127.0.0.1 callback, or
#  expose it over HTTPS via Tailscale Serve / a reverse proxy.)
WIKIPEDIA_OAUTH_CLIENT_ID=
WIKIPEDIA_OAUTH_CLIENT_SECRET=
WIKIPEDIA_OAUTH_CALLBACK=http://127.0.0.1:8766/wiki/oauth/callback
