# Wikimedia API エチケットで User-Agent に明記する GitHub リポジトリ URL
# 例: https://github.com/your-name/wiki-gap
WIKI_GAP_CONTACT_URL=https://github.com/PLACEHOLDER/wiki-gap

# SQLite DB ファイルの場所 (デフォルト: data/wiki_gap.db)
WIKI_GAP_DB_PATH=data/wiki_gap.db

# クロールのレート制限 (req/sec)
WIKI_GAP_RATE_LIMIT=1.5

# Wikidata SPARQL endpoint
WIKIDATA_SPARQL_ENDPOINT=https://query.wikidata.org/sparql

# Dashboard bind 設定 (Tailscale IP 推奨。public IP には漏らさない)
# Hetzner agent-team の Tailscale IP は `tailscale ip -4` で確認
WIKI_GAP_BIND_HOST=100.104.67.25
WIKI_GAP_BIND_PORT=8766

# Phase 2B: Wikipedia OAuth 2.0 認証
# https://meta.wikimedia.org/wiki/Special:OAuthConsumerRegistration/propose で
# 登録した Consumer の key/secret を入れる
WIKIPEDIA_OAUTH_CLIENT_ID=
WIKIPEDIA_OAUTH_CLIENT_SECRET=
# OAuth callback URL (Consumer 登録時の "OAuth callback URL" と一致させる)
WIKIPEDIA_OAUTH_CALLBACK=http://100.104.67.25:8766/wiki/oauth/callback
